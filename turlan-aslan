<!doctype html>
<html lang="kk" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DiffEq Hub - Дифференциалдық Модельдер</title>
  <script src="https://cdn.tailwindcss.com/3.4.7"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4"></script>
  <script src="https://polyfill.io/v3/polyfill.min.js?features=es6"></script>
  <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', 'Arial', 'Helvetica', sans-serif; }
    html, body { height: 100%; margin: 0; }
    .app-wrapper { height: 100%; width: 100%; overflow-y: auto; overflow-x: hidden; background: #ffffff; }
    .gradient-bg { background: linear-gradient(135deg, #2c3e50, #34495e); }
    .gradient-text { color: #2c3e50; font-weight: bold; }
    .card-hover { transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease; border: 1px solid #d0d0d0; }
    .card-hover:hover { transform: translateY(-4px); box-shadow: 0 4px 20px rgba(0,0,0,0.1); border-color: #2c3e50; }
    .nav-link { transition: color 0.2s ease, background-color 0.2s ease; }
    .nav-link:hover { color: #ecf0f1; background-color: rgba(255,255,255,0.1); border-radius: 8px; }
    .modal-overlay { background-color: rgba(0, 0, 0, 0.5); }
    .fade-in { animation: fadeIn 0.5s ease-in-out; }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    .slide-in { animation: slideIn 0.3s ease-out; }
    @keyframes slideIn { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    .timeline-item { position: relative; padding-left: 30px; }
    .timeline-item::before { content: ''; position: absolute; left: 0; top: 8px; width: 12px; height: 12px; border-radius: 50%; background: #2c3e50; }
    .timeline-item::after { content: ''; position: absolute; left: 5px; top: 24px; width: 2px; height: calc(100% - 16px); background: #bdc3c7; }
    .timeline-item:last-child::after { display: none; }
    .btn-gradient { background: linear-gradient(135deg, #2c3e50, #34495e); color: white; transition: background 0.2s ease, transform 0.2s ease; border: none; cursor: pointer; border-radius: 8px; }
    .btn-gradient:hover { background: linear-gradient(135deg, #34495e, #2c3e50); transform: translateY(-2px); }
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #ecf0f1; }
    ::-webkit-scrollbar-thumb { background: #95a5a6; border-radius: 4px; }
    /* Есептер үшін қосымша стильдер */
    .problem-card { transition: all 0.2s ease; }
    .answer-input { transition: all 0.3s ease; }
    .answer-input.correct { background-color: #d1fae5; border-color: #10b981; }
    .answer-input.wrong { background-color: #fee2e2; border-color: #ef4444; }
  </style>
</head>
<body class="h-full bg-white">
  <div class="app-wrapper">
    <!-- Navigation -->
    <nav class="gradient-bg fixed top-0 left-0 right-0 z-50 border-bottom" style="border-bottom: 1px solid #34495e;">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="#" onclick="navigateTo('home')" class="flex items-center space-x-3 cursor-pointer">
            <div class="flex items-center">
              <div class="hidden sm:block">
                <span class="text-white font-bold text-lg" id="site-title">DiffEq Hub</span>
                <span class="text-white text-xs block -mt-1" style="opacity: 0.8;">Дифференциалдық Модельдер</span>
              </div>
            </div>
          </a>
          <div class="hidden md:flex items-center space-x-1">
            <a href="#" onclick="navigateTo('home')" class="nav-link text-white px-4 py-2 rounded-lg font-medium">Басты бет</a>
            <a href="#" onclick="navigateTo('history')" class="nav-link text-white/90 px-4 py-2 rounded-lg font-medium">Тарих</a>
            <a href="#" onclick="navigateTo('models')" class="nav-link text-white/90 px-4 py-2 rounded-lg font-medium">Модельдер</a>
            <a href="#" onclick="navigateTo('problems')" class="nav-link text-white/90 px-4 py-2 rounded-lg font-medium">Есептер</a>
            <a href="#" onclick="navigateTo('contact')" class="nav-link text-white/90 px-4 py-2 rounded-lg font-medium">Контакт</a>
          </div>
          <button onclick="toggleMobileMenu()" class="md:hidden text-white p-2">
            <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>
      <div id="mobile-menu" class="hidden md:hidden bg-white border-top" style="border-top: 1px solid #d0d0d0;">
        <div class="px-4 py-3 space-y-2">
          <a href="#" onclick="navigateTo('home'); toggleMobileMenu();" class="block text-gray-800 px-4 py-2 rounded-lg hover:bg-gray-100">Басты бет</a>
          <a href="#" onclick="navigateTo('history'); toggleMobileMenu();" class="block text-gray-800 px-4 py-2 rounded-lg hover:bg-gray-100">Тарих</a>
          <a href="#" onclick="navigateTo('models'); toggleMobileMenu();" class="block text-gray-800 px-4 py-2 rounded-lg hover:bg-gray-100">Модельдер</a>
          <a href="#" onclick="navigateTo('problems'); toggleMobileMenu();" class="block text-gray-800 px-4 py-2 rounded-lg hover:bg-gray-100">Есептер</a>
          <a href="#" onclick="navigateTo('contact'); toggleMobileMenu();" class="block text-gray-800 px-4 py-2 rounded-lg hover:bg-gray-100">Контакт</a>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="pt-16">
      
      <!-- Home Page -->
      <section id="page-home" class="page-section">
        <div class="gradient-bg relative overflow-hidden" style="background: #2c3e50;">
          <div class="absolute inset-0 opacity-5">
            <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
              <defs><pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse"><path d="M 10 0 L 0 0 0 10" fill="none" stroke="black" stroke-width="0.5" /></pattern></defs>
              <rect width="100" height="100" fill="url(#grid)" />
            </svg>
          </div>
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32 relative">
            <div class="text-center fade-in">
              <h1 id="hero-title" class="text-3xl sm:text-4xl md:text-5xl lg:text-5xl font-bold text-white mb-10 leading-tight">Дифференциалдық модельдер</h1>
              <div class="flex justify-center space-x-4">
                <button onclick="navigateTo('models')" class="btn-gradient font-semibold px-8 py-3 rounded text-lg">Модельдерді зерттеу →</button>
                <button onclick="navigateTo('problems')" class="bg-white/10 text-white border border-white/30 hover:bg-white/20 transition font-semibold px-8 py-3 rounded text-lg">Есептер шығару</button>
              </div>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 right-0">
            <svg viewBox="0 0 1440 100" fill="none" class="w-full"><path d="M0 50 Q360 0 720 50 T1440 50 V100 H0 Z" fill="white" /></svg>
          </div>
        </div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
          <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-bold gradient-text mb-4">Дифференциалдық теңдеулердің тарихы</h2>
            <p class="text-gray-600 max-w-2xl mx-auto">17 ғасырдан бастап қазіргі күнге дейінгі даму жолы</p>
          </div>
          <div class="grid md:grid-cols-2 gap-8 mb-12">
            <div class="bg-white rounded p-8" style="border: 1px solid #d0d0d0;">
              <div class="space-y-6">
                <div class="timeline-item pb-6">
                  <h3 class="font-bold text-gray-800 mb-2">17 ғасыр - Бастауы</h3>
                  <p class="text-gray-600 text-sm">Дифференциалдық теңдеулер Исаак Ньютон және Готфрид Лейбницпен ойлап табылған.</p>
                </div>
                <div class="timeline-item pb-6">
                  <h3 class="font-bold text-gray-800 mb-2">Неге ойлап табылды?</h3>
                  <p class="text-gray-600 text-sm">Бұл теңдеулер табиғат құбылыстарын дәл болжау үшін жасалған: планеталар қозғалысы, популяция өсуі, жылу таралу сияқты.</p>
                </div>
                <div class="timeline-item">
                  <h3 class="font-bold text-gray-800 mb-2">Қазіргі қолданысы</h3>
                  <p class="text-gray-600 text-sm">Кейін Эйлер, Лагранж, Фурье дамытты. Қазір инженерлік, экономика, экологияда қолданылады.</p>
                </div>
              </div>
            </div>
            <div class="space-y-4">
              <div class="bg-white rounded p-6" style="border: 1px solid #d0d0d0;">
                <h4 class="font-bold text-gray-800 mb-2">Исаак Ньютон (1643-1727)</h4>
                <p class="text-gray-600 text-sm">Ағылшын физигі. Механика заңдарын сипаттау үшін дифференциалдық есептеуді қолданды.</p>
              </div>
              <div class="bg-white rounded p-6" style="border: 1px solid #d0d0d0;">
                <h4 class="font-bold text-gray-800 mb-2">Готфрид Лейбниц (1646-1716)</h4>
                <p class="text-gray-600 text-sm">Неміс философы. Қазіргі дифференциалдық белгілеуді (dx, dy, ∫) ойлап тапты.</p>
              </div>
            </div>
          </div>
          <div class="text-center">
            <button onclick="navigateTo('history')" class="text-blue-600 font-semibold hover:text-blue-800 transition-colors"> Толық тарихты оқу → </button>
          </div>
        </div>
      </section>

      <!-- History Page -->
      <section id="page-history" class="page-section hidden">
        <div class="gradient-bg py-16">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">Дифференциалдық теңдеулердің тарихы</h1>
            <p class="text-white/80">17 ғасырдан бастап қазіргі күнге дейін</p>
          </div>
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
          <div class="mb-16">
            <h2 class="text-2xl font-bold gradient-text mb-8 text-center">Негізін қалаушылар</h2>
            <div class="grid md:grid-cols-2 gap-8">
              <div class="bg-white rounded-2xl shadow-xl p-8 fade-in">
                <div class="flex items-start space-x-6">
                  <div class="w-24 h-24 rounded-full gradient-bg flex items-center justify-center flex-shrink-0"><span class="text-4xl">🍎</span></div>
                  <div>
                    <h3 class="text-xl font-bold text-gray-800 mb-2">Исаак Ньютон (1643-1727)</h3>
                    <p class="text-gray-600 text-sm leading-relaxed">Механика заңдарын сипаттау үшін дифференциалдық есептеуді қолданды. "Флюксиялар әдісі" деп атаған жүйесін жасады.</p>
                  </div>
                </div>
              </div>
              <div class="bg-white rounded-2xl shadow-xl p-8 fade-in">
                <div class="flex items-start space-x-6">
                  <div class="w-24 h-24 rounded-full gradient-bg flex items-center justify-center flex-shrink-0"><span class="text-4xl font-bold text-white">∫</span></div>
                  <div>
                    <h3 class="text-xl font-bold text-gray-800 mb-2">Готфрид Лейбниц (1646-1716)</h3>
                    <p class="text-gray-600 text-sm leading-relaxed">Қазіргі дифференциалдық белгілеуді (dx, dy, ∫) ойлап тапты. Математикалық талдаудың негізін қалады.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="mb-16">
            <h2 class="text-2xl font-bold gradient-text mb-8 text-center">Даму кезеңдері</h2>
            <div class="bg-white rounded-2xl shadow-xl p-8">
              <div class="space-y-8">
                <div class="timeline-item pb-8">
                  <h3 class="font-bold text-gray-800 mb-2">Негіздің қалануы (1665-1676)</h3>
                  <p class="text-gray-600">Ньютон мен Лейбниц дифференциалдық және интегралдық есептеуді дербес түрде жасады.</p>
                </div>
                <div class="timeline-item pb-8">
                  <h3 class="font-bold text-gray-800 mb-2">Эйлер мен Лагранж дәуірі (18 ғасыр)</h3>
                  <p class="text-gray-600">Леонард Эйлер мен Жозеф-Луи Лагранж шешудің көптеген әдістерін жасады.</p>
                </div>
                <div class="timeline-item">
                  <h3 class="font-bold text-gray-800 mb-2">Фурье және компьютерлік дәуір (19 - 21 ғасыр)</h3>
                  <p class="text-gray-600">Компьютерлік модельдеу арқылы күрделі дифференциалдық теңдеулерді шешу мүмкін болды.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Models Page -->
      <section id="page-models" class="page-section hidden">
        <div class="gradient-bg py-16">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">Математикалық модельдер</h1>
            <p class="text-white/80">Интерактивті графиктер мен симуляциялар</p>
          </div>
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
            <div class="card-hover bg-white rounded-2xl shadow-xl overflow-hidden cursor-pointer" onclick="openModel('harmonic')">
              <div class="h-48 gradient-bg flex items-center justify-center relative">
                <svg viewBox="0 0 200 100" class="w-4/5 absolute">
                  <path d="M10 50 Q35 10, 60 50 T110 50 T160 50 T190 50" stroke="white" stroke-width="3" fill="none" opacity="0.9"></path>
                </svg>
                <div class="absolute top-4 right-4 bg-white/20 backdrop-blur-sm rounded-full px-3 py-1"><span class="text-white text-xs font-medium">Физика</span></div>
              </div>
              <div class="p-6">
                <h3 class="font-bold text-xl text-gray-800 mb-2">Гармоникалық тербеліс</h3>
                <p class="text-gray-600 text-sm mb-4">Серіппелі жүйелер мен маятниктердегі тербелмелі қозғалыс.</p>
              </div>
            </div>
            <div class="card-hover bg-white rounded-2xl shadow-xl overflow-hidden cursor-pointer" onclick="openModel('seismograph')">
              <div class="h-48 bg-gradient-to-br from-red-500 to-orange-500 flex items-center justify-center relative">
                <svg viewBox="0 0 200 100" class="w-4/5"><path d="M10 50 L30 50 L35 30 L45 70 L55 20 L65 80 L75 40 L85 60 L95 45 L105 55 L190 50" stroke="white" stroke-width="2" fill="none"></path></svg>
                <div class="absolute top-4 right-4 bg-white/20 backdrop-blur-sm rounded-full px-3 py-1"><span class="text-white text-xs font-medium">Сейсмология</span></div>
              </div>
              <div class="p-6">
                <h3 class="font-bold text-xl text-gray-800 mb-2">Сейсмограф моделі</h3>
                <p class="text-gray-600 text-sm mb-4">Жер сілкінісінің магнитудасын өлшеу және толқын таралуы.</p>
              </div>
            </div>
            <div class="card-hover bg-white rounded-2xl shadow-xl overflow-hidden cursor-pointer" onclick="openModel('population')">
              <div class="h-48 bg-gradient-to-br from-green-500 to-teal-500 flex items-center justify-center relative">
                <svg viewBox="0 0 200 100" class="w-4/5"><path d="M10 90 Q30 88, 50 80 Q80 60, 100 40 Q130 20, 160 15 Q180 12, 190 12" stroke="white" stroke-width="3" fill="none" /></svg>
                <div class="absolute top-4 right-4 bg-white/20 backdrop-blur-sm rounded-full px-3 py-1"><span class="text-white text-xs font-medium">Биология</span></div>
              </div>
              <div class="p-6">
                <h3 class="font-bold text-xl text-gray-800 mb-2">Популяция өсуі</h3>
                <p class="text-gray-600 text-sm mb-4">Логистикалық өсу моделі - популяция динамикасы.</p>
              </div>
            </div>
            <div class="card-hover bg-white rounded-2xl shadow-xl overflow-hidden cursor-pointer" onclick="openModel('interest')">
              <div class="h-48 bg-gradient-to-br from-yellow-500 to-amber-500 flex items-center justify-center relative">
                <svg viewBox="0 0 200 100" class="w-4/5"><path d="M10 85 Q40 75, 70 55 Q100 30, 130 15 Q160 5, 190 2" stroke="white" stroke-width="3" fill="none" /><text x="150" y="70" fill="white" font-size="30" font-weight="bold" opacity="0.8">$</text></svg>
                <div class="absolute top-4 right-4 bg-white/20 backdrop-blur-sm rounded-full px-3 py-1"><span class="text-white text-xs font-medium">Экономика</span></div>
              </div>
              <div class="p-6">
                <h3 class="font-bold text-xl text-gray-800 mb-2">Үздіксіз пайыздар</h3>
                <p class="text-gray-600 text-sm mb-4">Экспоненциалды өсу - банк салымдары мен инвестициялар.</p>
              </div>
            </div>
            <div class="card-hover bg-white rounded-2xl shadow-xl overflow-hidden cursor-pointer" onclick="openModel('temperature')">
              <div class="h-48 bg-gradient-to-br from-cyan-500 to-blue-500 flex items-center justify-center relative">
                <svg viewBox="0 0 200 100" class="w-4/5"><text x="75" y="55" fill="white" font-size="14" font-weight="bold">T(x,t)</text></svg>
                <div class="absolute top-4 right-4 bg-white/20 backdrop-blur-sm rounded-full px-3 py-1"><span class="text-white text-xs font-medium">Термодинамика</span></div>
              </div>
              <div class="p-6">
                <h3 class="font-bold text-xl text-gray-800 mb-2">Жылу таралуы</h3>
                <p class="text-gray-600 text-sm mb-4">Ньютонның салқындау заңы және жылу өткізгіштік теңдеуі.</p>
              </div>
            </div>
            <div class="card-hover bg-white rounded-2xl shadow-xl overflow-hidden cursor-pointer" onclick="openModel('pollution')">
              <div class="h-48 bg-gradient-to-br from-gray-600 to-gray-800 flex items-center justify-center relative">
                <svg viewBox="0 0 200 100" class="w-4/5"><circle cx="100" cy="50" r="20" fill="white" opacity="0.6" /></svg>
                <div class="absolute top-4 right-4 bg-white/20 backdrop-blur-sm rounded-full px-3 py-1"><span class="text-white text-xs font-medium">Экология</span></div>
              </div>
              <div class="p-6">
                <h3 class="font-bold text-xl text-gray-800 mb-2">Ластану таралуы</h3>
                <p class="text-gray-600 text-sm mb-4">Диффузия теңдеуі - ауа мен судағы ластаушы заттардың таралуы.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Есептер бөлімі (Problems) -->
      <section id="page-problems" class="page-section hidden">
        <div class="gradient-bg py-16">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">Есептер</h1>
            <p class="text-white/80 max-w-2xl mx-auto">Дифференциалдық теңдеулер теориясының жаратылыстану пәндеріндегі қолданылуына арналған интерактивті есептер.</p>
          </div>
        </div>
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
          <div id="problems-container" class="space-y-12"></div>
        </div>
      </section>

      <!-- Contact Page -->
      <section id="page-contact" class="page-section hidden">
        <div class="gradient-bg py-16">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">Бізбен байланысыңыз</h1>
            <p class="text-white/80">Сұрақтарыңыз бен ұсыныстарыңызды жіберіңіз</p>
          </div>
        </div>
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
          <div class="grid md:grid-cols-2 gap-8">
            <div class="bg-white rounded-2xl shadow-xl p-8">
              <h2 class="text-xl font-bold text-gray-800 mb-6">Хабарлама жіберу</h2>
