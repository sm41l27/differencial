    function toggleMobileMenu() {
      document.getElementById('mobile-menu').classList.toggle('hidden');
    }

    // ====================== МОДЕЛЬДЕР МЕН ГРАФИКТЕР (С ЕКІ СЫЗЫҚПЕН) ======================
    let currentChart = null;

    const modelData = {
      harmonic: {
        title: 'Гармоникалық тербеліс',
        equation: '\\frac{d^2y}{dt^2} + \\omega^2 y = 0',
        solution: 'y(t) = A \\cos(\\omega t + \\phi)',
        description: 'Гармоникалық тербеліс. Серіппедегі жүк, маятник, электр тізбегіндегі ток тербелістері осы модельмен сипатталады.',
        applications: ['Серіппелі жүйелер', 'Қарапайым маятник', 'Электр тізбектері', 'Акустикалық толқындар'],
        params: { A: 2, omega: 1, phi: 0 },
        category: 'Физика'
      },
      seismograph: {
        title: 'Сейсмограф моделі',
        equation: 'M = \\log_{10}\\left(\\frac{A}{A_0}\\right)',
        solution: 'x(t) = A e^{-\\gamma t} \\sin(\\omega t)',
        description: 'Сейсмограф жер сілкінісі толқындарын тіркейді. Демпферленген тербеліс теңдеуі сейсмографтың жауабын сипаттайды.',
        applications: ['Жер сілкінісін өлшеу', 'Сейсмикалық зерттеулер', 'Құрылыс қауіпсіздігі'],
        params: { A: 5, gamma: 0.3, omega: 2 },
        category: 'Сейсмология'
      },
      population: {
        title: 'Популяция өсуі',
        equation: '\\frac{dP}{dt} = rP\\left(1 - \\frac{P}{K}\\right)',
        solution: 'P(t) = \\frac{K}{1 + \\left(\\frac{K-P_0}{P_0}\\right)e^{-rt}}',
        description: 'Логистикалық өсу моделі шектеулі ресурстар жағдайындағы популяция динамикасын сипаттайды.',
        applications: ['Жануарлар популяциясы', 'Бактериялар өсуі', 'Эпидемиология'],
        params: { K: 100, r: 0.5, P0: 10 },
        category: 'Биология'
      },
      interest: {
        title: 'Үздіксіз пайыздар',
        equation: '\\frac{dA}{dt} = rA',
        solution: 'A(t) = A_0 e^{rt}',
        description: 'Үздіксіз құрама пайыз формуласы қаржылық өсуді модельдейді.',
        applications: ['Банк салымдары', 'Инвестициялық портфель', 'Инфляция есептеу'],
        params: { A0: 1000, r: 0.05 },
        category: 'Экономика'
      },
      temperature: {
        title: 'Жылу таралуы',
        equation: '\\frac{dT}{dt} = -k(T - T_s)',
        solution: 'T(t) = T_s + (T_0 - T_s)e^{-kt}',
        description: 'Ньютонның салқындау заңы дененің температурасының қоршаған орта температурасына жақындауын сипаттайды.',
        applications: ['Ғимараттарды жылыту/салқындату', 'Криминалистика', 'Тамақ өнеркәсібі'],
        params: { T0: 100, Ts: 20, k: 0.1 },
        category: 'Термодинамика'
      },
      pollution: {
        title: 'Ластану таралуы',
        equation: '\\frac{\\partial C}{\\partial t} = D \\nabla^2 C - \\lambda C',
        solution: 'C(x,t) = \\frac{M}{\\sqrt{4\\pi Dt}} e^{-\\frac{x^2}{4Dt}}',
        description: 'Диффузия теңдеуі ластаушы заттардың ауада немесе суда таралуын сипаттайды.',
        applications: ['Ауа сапасын модельдеу', 'Су ластануы', 'Өнеркәсіптік шығарындылар'],
        params: { D: 1, M: 100, lambda: 0.01 },
        category: 'Экология'
      }
    };

    function openModel(modelId) {
      const model = modelData[modelId];
      if (!model) return;
      document.getElementById('modal-title').textContent = model.title;
      
      const infoHtml = `
        <div>
          <span class="inline-block bg-purple-100 text-purple-700 text-xs font-bold px-3 py-1 rounded-full mb-4">${model.category}</span>
          <h3 class="font-bold text-gray-800 mb-2">Дифференциалдық теңдеу</h3>
          <div class="bg-gray-100 rounded-lg p-4 text-center"><span class="text-lg">\\[${model.equation}\\]</span></div>
        </div>
        <div>
          <h3 class="font-bold text-gray-800 mb-2 mt-4">Шешімі</h3>
          <div class="bg-blue-50 rounded-lg p-4 text-center"><span>\\[${model.solution}\\]</span></div>
        </div>
        <div class="mt-4">
          <p class="text-gray-600 text-sm leading-relaxed">${model.description}</p>
        </div>
        <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded mt-4">
          <p class="text-green-800 text-xs font-medium">💡 <strong>Ескерту:</strong> Графикте дифференциалдық шешім (көк түс) және қарапайым (сызықтық/жуықталған) шешім (қызыл үзік сызық) салыстырылған.</p>
        </div>
      `;
      document.getElementById('model-info').innerHTML = infoHtml;
      
      let controlsHtml = '<div class="grid grid-cols-2 gap-3">';
      for (const [key, value] of Object.entries(model.params)) {
        controlsHtml += `
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">${key}</label>
            <input type="number" id="param-${key}" value="${value}" step="0.1" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500" onchange="updateChart('${modelId}')">
          </div>`;
      }
      controlsHtml += `</div><button onclick="updateChart('${modelId}')" class="mt-4 w-full btn-gradient text-white font-medium py-2 rounded-lg text-sm">Графикті жаңарту</button>`;
      
      document.getElementById('chart-controls').innerHTML = controlsHtml;
      document.getElementById('model-modal').classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      
      if (window.MathJax) MathJax.typesetPromise();
      setTimeout(() => createChart(modelId, model.params), 100);
    }

    function getParams(modelId) {
      const model = modelData[modelId];
      const params = {};
      for (const key of Object.keys(model.params)) {
        const input = document.getElementById(`param-${key}`);
        params[key] = input ? parseFloat(input.value) : model.params[key];
      }
      return params;
    }

    // Здесь генерируются ОБА графика (Дифференциальный и Простой)
    function generateChartData(modelId, params) {
      const t = [];
      const n = 100;
      const tMax = (modelId === 'population' || modelId === 'interest') ? 20 : 10;
      for (let i = 0; i <= n; i++) t.push((i * tMax / n).toFixed(2));
      
      let datasets = [];
      let yLabel = 'y(t)', xLabel = 't (уақыт)';
      
      switch (modelId) {
        case 'harmonic':
          datasets = [
            { label: 'Дифференциалдық шешім', data: t.map(ti => params.A * Math.cos(params.omega * ti + params.phi)), borderColor: '#667eea', backgroundColor: 'rgba(102, 126, 234, 0.1)', borderWidth: 2.5, fill: true, tension: 0.4, pointRadius: 0 },
            { label: 'Қарапайым (параболалық жуықтау)', data: t.map(ti => params.A - 0.5 * params.omega * params.omega * params.A * (ti * ti / 2)), borderColor: '#ef4444', borderWidth: 2, borderDash: [5, 5], fill: false, tension: 0.4, pointRadius: 0 }
          ];
          yLabel = 'y(t) - ығысу';
          break;
        case 'seismograph':
          datasets = [
            { label: 'Дифференциалдық шешім', data: t.map(ti => params.A * Math.exp(-params.gamma * ti) * Math.sin(params.omega * ti)), borderColor: '#667eea', backgroundColor: 'rgba(102, 126, 234, 0.1)', borderWidth: 2.5, fill: true, tension: 0.4, pointRadius: 0 },
            { label: 'Қарапайым (тек өшу)', data: t.map(ti => params.A * Math.exp(-params.gamma * ti * 0.5)), borderColor: '#ef4444', borderWidth: 2, borderDash: [5, 5], fill: false, tension: 0.4, pointRadius: 0 }
          ];
          yLabel = 'x(t) - амплитуда';
          break;
        case 'population':
          datasets = [
            { label: 'Дифференциалдық (Логистикалық)', data: t.map(ti => params.K / (1 + ((params.K - params.P0) / params.P0) * Math.exp(-params.r * ti))), borderColor: '#667eea', backgroundColor: 'rgba(102, 126, 234, 0.1)', borderWidth: 2.5, fill: true, tension: 0.4, pointRadius: 0 },
            { label: 'Қарапайым (Шексіз экспонента)', data: t.map(ti => params.P0 * Math.exp(params.r * ti * 0.5)), borderColor: '#ef4444', borderWidth: 2, borderDash: [5, 5], fill: false, tension: 0.4, pointRadius: 0 }
          ];
          yLabel = 'P(t) - популяция';
          break;
        case 'interest':
          datasets = [
            { label: 'Дифференциалдық (Күрделі пайыз)', data: t.map(ti => params.A0 * Math.exp(params.r * ti)), borderColor: '#667eea', backgroundColor: 'rgba(102, 126, 234, 0.1)', borderWidth: 2.5, fill: true, tension: 0.4, pointRadius: 0 },
            { label: 'Қарапайым (Жай пайыз)', data: t.map(ti => params.A0 * (1 + params.r * ti)), borderColor: '#ef4444', borderWidth: 2, borderDash: [5, 5], fill: false, tension: 0.4, pointRadius: 0 }
          ];
          yLabel = 'A(t) - сома';
          xLabel = 't (жыл)';
          break;
        case 'temperature':
          datasets = [
            { label: 'Дифференциалдық шешім', data: t.map(ti => params.Ts + (params.T0 - params.Ts) * Math.exp(-params.k * ti)), borderColor: '#667eea', backgroundColor: 'rgba(102, 126, 234, 0.1)', borderWidth: 2.5, fill: true, tension: 0.4, pointRadius: 0 },
            { label: 'Қарапайым (Сызықтық суу)', data: t.map(ti => Math.max(params.Ts, params.T0 - params.k * (params.T0 - params.Ts) * ti * 5)), borderColor: '#ef4444', borderWidth: 2, borderDash: [5, 5], fill: false, tension: 0.4, pointRadius: 0 }
          ];
          yLabel = 'T(t) - температура (°C)';
          break;
        case 'pollution':
          const x = [];
          for (let i = -5; i <= 5; i += 0.1) x.push(i.toFixed(1));
          const t1 = 5;
          datasets = [
            { label: 'Дифференциалдық (ыдыраумен)', data: x.map(xi => {
                if (t1 <= 0) return 0;
                return (params.M / Math.sqrt(4 * Math.PI * params.D * t1)) * Math.exp(-parseFloat(xi)*parseFloat(xi) / (4 * params.D * t1)) * Math.exp(-params.lambda * t1);
              }), borderColor: '#667eea', borderWidth: 2.5, fill: false, tension: 0.4, pointRadius: 0 },
            { label: 'Қарапайым (ыдыраусыз)', data: x.map(xi => {
                if (t1 <= 0) return 0;
                return (params.M / Math.sqrt(4 * Math.PI * params.D * t1)) * Math.exp(-parseFloat(xi)*parseFloat(xi) / (4 * params.D * t1));
              }), borderColor: '#ef4444', borderWidth: 2, borderDash: [5, 5], fill: false, tension: 0.4, pointRadius: 0 }
          ];
          return { labels: x, datasets, yLabel: 'C(x,t) - концентрация', xLabel: 'x - қашықтық' };
      }
      return { labels: t, datasets, yLabel, xLabel };
    }

    function createChart(modelId, params) {
      const ctx = document.getElementById('model-chart').getContext('2d');
      if (currentChart) currentChart.destroy();
      const data = generateChartData(modelId, params);
      currentChart = new Chart(ctx, {
        type: 'line',
        data: { labels: data.labels, datasets: data.datasets },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { position: 'top', labels: { usePointStyle: true, font: { size: 12 } } } },
          scales: {
            x: { title: { display: true, text: data.xLabel } },
            y: { title: { display: true, text: data.yLabel } }
          },
          interaction: { intersect: false, mode: 'index' }
        }
      });
    }

    function updateChart(modelId) {
      createChart(modelId, getParams(modelId));
    }

    function closeModal() {
      document.getElementById('model-modal').classList.add('hidden');
      document.body.style.overflow = 'auto';
      if (currentChart) { currentChart.destroy(); currentChart = null; }
    }

    // ====================== ЕСЕПТЕР (ТҮЗЕТІЛГЕН ДИЗАЙН) ======================
    const problemsData = [
      {
