    function renderProblems() {
      const container = document.getElementById('problems-container');
      container.innerHTML = '';

      const categories = {};
      problemsData.forEach(p => {
        if (!categories[p.category]) categories[p.category] = [];
        categories[p.category].push(p);
      });

      Object.keys(categories).forEach(cat => {
        const sectionHTML = `
          <div class="mb-10">
            <h2 class="text-2xl font-bold gradient-text mb-6 flex items-center">
              <span class="inline-block w-3 h-3 bg-blue-600 rounded-full mr-3"></span>${cat}
            </h2>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              ${categories[cat].map(problem => `
                <div class="problem-card bg-white rounded-2xl shadow-lg p-6 border border-gray-200 hover:border-blue-300 flex flex-col justify-between">
                  <div>
                    <h4 class="font-semibold text-lg mb-3">${problem.title}</h4>
                    <p class="text-gray-600 text-sm mb-6 leading-relaxed">${problem.statement}</p>
                  </div>
                  
                  <!-- Изменённый дизайн: поле сверху, кнопки снизу -->
                  <div class="flex flex-col gap-3 mt-auto">
                    <input type="text" id="ans-input-${problem.id}" placeholder="Жауабыңыз (${problem.unit})"
                           class="answer-input w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 text-lg font-medium text-center">
                    
                    <div class="grid grid-cols-2 gap-3">
                      <button onclick="checkAnswer('${problem.id}')" class="btn-gradient text-white py-3 rounded-xl font-medium w-full text-sm">Тексеру</button>
                      <button onclick="showProblemSolution('${problem.id}')" class="bg-gray-100 hover:bg-gray-200 text-gray-700 py-3 rounded-xl font-medium w-full text-sm">Шешу жолы</button>
                    </div>
                  </div>
                  
                  <div id="result-${problem.id}" class="mt-4 text-sm font-medium hidden text-center"></div>
                  <div id="solution-${problem.id}" class="hidden mt-6 bg-blue-50 border border-blue-200 rounded-2xl p-5 text-sm leading-relaxed">
                    ${problem.solutionHtml}
                  </div>
                </div>
              `).join('')}
            </div>
          </div>
        `;
        container.innerHTML += sectionHTML;
      });

      if (window.MathJax) MathJax.typesetPromise();
    }

    window.checkAnswer = function(id) {
      const problem = problemsData.find(p => p.id === id);
      if (!problem) return;

      const inputEl = document.getElementById(`ans-input-${id}`);
      const resultEl = document.getElementById(`result-${id}`);
      const userAnswer = parseFloat(inputEl.value.trim());

      if (isNaN(userAnswer)) {
        resultEl.classList.remove('hidden');
        resultEl.innerHTML = `<span class="text-red-600">Сан енгізіңіз!</span>`;
        inputEl.classList.add('wrong');
        return;
      }

      const diff = Math.abs(userAnswer - problem.correctAnswer);
      if (diff <= problem.tolerance) {
        inputEl.classList.remove('wrong');
        inputEl.classList.add('correct');
        resultEl.classList.remove('hidden');
        resultEl.innerHTML = `<span class="text-green-600">✓ Дұрыс! Жауап: ${problem.correctAnswer}</span>`;
      } else {
        inputEl.classList.remove('correct');
        inputEl.classList.add('wrong');
        resultEl.classList.remove('hidden');
        resultEl.innerHTML = `<span class="text-red-600">✗ Қате. Қайтадан көріңіз.</span>`;
      }
    };

    window.showProblemSolution = function(id) {
      const solEl = document.getElementById(`solution-${id}`);
      solEl.classList.toggle('hidden');
      if (window.MathJax) MathJax.typesetPromise();
    };

    function handleContactSubmit(event) {
      event.preventDefault();
      const form = event.target;
      const btn = form.querySelector('button[type="submit"]');
      btn.disabled = true;
      btn.innerHTML = 'Жіберілуде...';
      setTimeout(() => {
        btn.disabled = false;
        btn.textContent = 'Жіберу';
        document.getElementById('form-success').classList.remove('hidden');
        form.reset();
        setTimeout(() => document.getElementById('form-success').classList.add('hidden'), 3000);
      }, 1500);
    }

    window.onload = function() {
      if (!document.getElementById('page-problems').classList.contains('hidden')) {
        renderProblems();
      }
    };
  </script>
</body>
</html>
